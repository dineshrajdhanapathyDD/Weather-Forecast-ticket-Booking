# Weather-Wise Flight Booking Agent - Environment Variables
# Copy this file to .env and fill in your actual API keys

# Weather API Key (WeatherAPI.com)
# Get your key from: https://www.weatherapi.com/
WEATHER_API_KEY=your_weather_api_key_here

# Fare API Key
FARE_API_KEY=your_fare_api_key_here

# Distance Matrix + Directions API Key (Google Maps)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# AWS Configuration
AWS_REGION=us-east-2
AWS_ACCOUNT_ID=your_aws_account_id

# Deployment Configuration
CDK_DEFAULT_REGION=us-east-2
CDK_DEFAULT_ACCOUNT=your_aws_account_id
