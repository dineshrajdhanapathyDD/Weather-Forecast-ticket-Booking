# Weather-Wise Flight Booking Agent - Secure Environment Variables
# 
# SECURITY NOTICE:
# - This is a template file. Copy to .env and fill in actual values
# - NEVER commit .env file to version control
# - Use AWS Secrets Manager for production deployments
# - Rotate keys every 90 days
#
# Copy this file:
#   cp .env.secure.example .env
#
# Then edit .env with your actual API keys

# ============================================
# API Keys (Required)
# ============================================

# Weather API Key from WeatherAPI.com
# Get your free key at: https://www.weatherapi.com/signup.aspx
# Free tier: 1,000,000 calls/month
WEATHER_API_KEY=

# Fare API Key (Optional - currently using mock data)
# Replace with real API key when integrating with flight API
FARE_API_KEY=

# ============================================
# AWS Configuration (Optional)
# ============================================

# AWS Region for deployment
# Default: us-east-2
AWS_REGION=us-east-2

# AWS Account ID
# Find at: https://console.aws.amazon.com/billing/home#/account
AWS_ACCOUNT_ID=

# ============================================
# CDK Configuration (Optional)
# ============================================

# CDK deployment region
CDK_DEFAULT_REGION=us-east-2

# CDK deployment account
CDK_DEFAULT_ACCOUNT=

# ============================================
# Frontend Configuration (Auto-configured)
# ============================================

# API Gateway endpoint (auto-populated after deployment)
# Format: https://xxxxx.execute-api.us-east-2.amazonaws.com/prod
REACT_APP_API_ENDPOINT=

# ============================================
# Development Settings (Optional)
# ============================================

# Enable debug logging
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# Production Settings (Optional)
# ============================================

# Use AWS Secrets Manager for production
USE_SECRETS_MANAGER=false

# Secrets Manager secret names
WEATHER_API_SECRET_NAME=weather-wise/weather-api-key
FARE_API_SECRET_NAME=weather-wise/fare-api-key
